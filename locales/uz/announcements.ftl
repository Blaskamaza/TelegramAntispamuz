# Samurai Bot - O'zbek e'lonlar (Uzbek Announcements)
# Fluent format: https://projectfluent.org/
#
# Format: '---' belgilari bilan ajratilgan variantlar
# Har bir variant bir necha qatordan iborat bo'lishi mumkin

# ========== XUSH KELIBSIZ (WELCOME) ==========
announcement-welcome = 
    👋 <b>Xush kelibsiz!</b>
    
    Guruhimizga qo'shilganingizdan xursandmiz.
    Iltimos, qoidalarni o'qing: !rules ---
    🎉 <b>Yangi a'zo!</b>
    
    Assalomu alaykum! Guruhda aktiv bo'ling va do'stlar orttiring! ---
    ✨ <b>Salom!</b>
    
    Savollaringiz bo'lsa, bemalol adminlarga murojaat qiling.

# ========== KUNLIK E'LONLAR (DAILY) ==========
announcement-daily = 
    🌅 <b>Xayrli tong, do'stlar!</b>
    
    Bugun ham ajoyib kun bo'lsin! 😊 ---
    ☀️ <b>Assalomu alaykum!</b>
    
    Yangi kun, yangi imkoniyatlar! ---
    🌤 <b>Bugun qanday rejalaringiz bor?</b>
    
    Samarali kun o'tkazishingizni tilaymiz!

# ========== KECHQURUN (EVENING) ==========
announcement-evening = 
    🌙 <b>Xayrli kech!</b>
    
    Kunni yaxshi yakunlang va dam oling. ---
    ✨ <b>Kechki salom!</b>
    
    Ertaga yangi kuch bilan qaytishingizni tilaymiz! ---
    🌆 <b>Kun yakunida...</b>
    
    Bugun nima qiziqarli bo'ldi? Baham ko'ring! 💬

